# Copy this file to .env and fill in values
# DO NOT commit .env to git

# Required: Your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Pick ONE notification method (ntfy.sh is easiest — no signup)
# Generate a random topic: openssl rand -hex 8
NTFY_TOPIC=opendc-build-CHANGEME

# OR use Slack webhook instead
SLACK_WEBHOOK=

# Set to "true" to skip manual gate approvals (fully autonomous)
# Set to "false" to require `touch .approve-next` between phases
AUTO_APPROVE_PHASES=false
