{
  "name": "service-ai",
  "version": "0.0.1",
  "private": true,
  "description": "Service.AI — AI-native field service platform",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "dev": "turbo run dev",
    "db:migrate": "pnpm --filter @service-ai/db run db:migrate",
    "db:migrate:down": "pnpm --filter @service-ai/db run db:migrate:down",
    "seed": "pnpm --filter @service-ai/api run seed",
    "seed:reset": "pnpm --filter @service-ai/api run seed:reset",
    "seed:demo": "pnpm --filter @service-ai/api run seed:demo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "rollup": ">=3.30.0"
    }
  }
}
