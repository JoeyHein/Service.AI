{
  "name": "@service-ai/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Service.AI database package — Drizzle ORM schema and migrations",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./scope": "./src/scope.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "db:migrate": "psql $DATABASE_URL -f migrations/0001_health_checks.sql -f migrations/0002_tenancy_franchise.sql -f migrations/0003_rls_policies.sql",
    "db:migrate:down": "psql $DATABASE_URL -f migrations/0003_rls_policies.down.sql -f migrations/0002_tenancy_franchise.down.sql -f migrations/0001_health_checks.down.sql",
    "seed": "echo 'No seed data yet — implement in a future phase' && exit 0",
    "seed:reset": "echo 'No seed reset yet — implement in a future phase' && exit 0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.0.0",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
